# Quilombo Araucaria - Variaveis de Ambiente
# Copie este arquivo para .env e configure os valores reais.
# NUNCA commite o arquivo .env no git.

# Chave secreta Django (gere uma nova em producao):
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=mude-esta-chave-para-uma-chave-segura-em-producao

# Ambiente (False em producao obrigatoriamente)
DEBUG=False

# Hosts permitidos (separados por virgula)
ALLOWED_HOSTS=quilomboaraucaria.org,www.quilomboaraucaria.org,seudominio.vercel.app

# Origins confiaveis para CSRF
CSRF_TRUSTED_ORIGINS=https://quilomboaraucaria.org,https://www.quilomboaraucaria.org,https://seudominio.vercel.app

# Database PostgreSQL (OBRIGATORIO em producao - Vercel nao suporta SQLite)
# Use Neon (neon.tech), Supabase ou Railway para PostgreSQL gratis.
# Exemplo Neon:
DATABASE_URL=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Email (para formulario de contato em producao)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=quilomboaraucaria@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app
